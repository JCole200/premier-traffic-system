// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // Reverting to standard DATABASE_URL for maximum compatibility
  // If using Vercel Postgres, ensure the connection string is assigned to DATABASE_URL in the dashboard.
  url       = env("DATABASE_URL")
}

// Enums removed for SQLite compatibility; using string fields instead

model InventoryItem {
  id            String @id // e.g. 'audio-podcast-unbelievable'
  name          String
  type          String // 'AUDIO', 'DISPLAY', 'BESPOKE_ESEND', 'ADS_IN_ESEND'
  category      String @default("AUDIO")
  emailType     String? // only for EMAIL category
  totalCapacity Int
  unit          String
  bookings      Booking[]
}

model Booking {
  id                 String   @id @default(uuid())
  clientName         String
  campaignName       String
  startDate          DateTime
  endDate            DateTime
  status             String   @default("CONFIRMED")
  isBlocked          Boolean  @default(false)
  
  // New Fields
  contractNumber     String?
  bookerName         String?
  bookingType        String?  // 'AUDIO', 'DISPLAY', 'BESPOKE_ESEND', 'ADS_IN_ESEND'
  department         String   @default("SALES") // SALES, MARKETING, FUNDRAISING, INTERNAL
  category           String   @default("PAID")  // PAID, GIFT, FILLER, INTERNAL
  additionalDetails  String?  // JSON string for extra fields (targeting, websites, etc.)

  // Inventory Requests
  audioSpots         Int      @default(0)
  displayImpressions Int      @default(0)
  
  // Relations
  audioTargetId      String?
  audioTarget        InventoryItem? @relation(fields: [audioTargetId], references: [id])
  
  emailDates         String?  // Storing as JSON string for SQLite simplicity: "['2026-01-01', ...]"
  geoTarget          String   @default("GLOBAL")
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  expiresAt          DateTime? // For reservations
  lastAlertSentAt    DateTime? // Track sent reminders
  auditLogs          AuditLog[]
}

model AuditLog {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  action      String   // 'CREATE', 'UPDATE', 'DELETE'
  field       String?  // Which field changed
  oldValue    String?  // JSON or string
  newValue    String?  // JSON or string
  changedBy   String?  // Name or ID of user
  createdAt   DateTime @default(now())
}
model BookingRule {
  id               String   @id @default(uuid())
  name             String
  category         String   // The category this rule applies to
  conflictsWith    String   @default("[]") // JSON array of categories it cannot overlap with
  maxDaily         Int      @default(1)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
model ESendArchive {
  id        String   @id @default(uuid())
  title     String
  copy      String   // full e-send copy
  link      String   // URL to the live e-send
  type      String
  createdAt DateTime @default(now())
}
